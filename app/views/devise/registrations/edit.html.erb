<!-- app/views/devise/registrations/edit.html.erb -->
<h2><%= t('devise.registrations.edit.title') %></h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email, t('devise.registrations.edit.email_label') %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div class="field">
    <%= f.label :password, t('devise.registrations.edit.password_label') %><br />
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, t('devise.registrations.edit.password_confirmation_label') %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :current_password, t('devise.registrations.edit.current_password_label') %><br />
    <%= f.password_field :current_password, autocomplete: "current-password" %>
  </div>

  <div class="field">
    <%= f.label :postal_code, t('devise.registrations.edit.postal_code_label') %><br />
    <%= f.text_field :postal_code %>
  </div>

  <div class="field">
    <%= f.label :address, t('devise.registrations.edit.address_label') %><br />
    <%= f.text_field :address %>
  </div>

  <div class="field">
    <%= f.label :bio, t('devise.registrations.edit.bio_label') %><br />
    <%= f.text_area :bio, rows: 4 %>
  </div>

  <div class="actions">
    <%= f.submit t('devise.registrations.edit.submit'), class: "btn btn-primary" %>
  </div>
<% end %>

<%= link_to t('devise.registrations.edit.delete_account'), registration_path(resource_name), data: { confirm: t('devise.registrations.edit.delete_confirm') }, method: :delete %><br />
<%= link_to t('devise.registrations.edit.back'), root_path %>
