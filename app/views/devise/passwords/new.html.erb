<h2><%= t('devise.passwords.new.title') %></h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email, t('devise.passwords.new.email_label') %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div class="actions">
    <%= f.submit t('devise.passwords.new.submit'), class: "btn btn-primary" %>
  </div>
<% end %>

<p class="mt-2">
  <%= link_to t('devise.passwords.new.back_to_login'), new_user_session_path %>
</p>
