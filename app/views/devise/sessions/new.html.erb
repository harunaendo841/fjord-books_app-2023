<h2><%= t('devise.sessions.new.title') %></h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email, t('devise.sessions.new.email_label') %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div class="field">
    <%= f.label :password, t('devise.sessions.new.password_label') %><br />
    <%= f.password_field :password, autocomplete: "current-password" %>
  </div>

  <div class="field">
    <%= f.check_box :remember_me %>
    <%= f.label :remember_me, t('devise.sessions.new.remember_me') %>
  </div>

  <div class="actions">
    <%= f.submit t('devise.sessions.new.submit'), class: "btn btn-primary" %>
  </div>
<% end %>

<p class="mt-2">
  <%= link_to t('devise.sessions.new.forgot_password'), new_user_password_path %> |
  <%= link_to t('devise.registrations.new.back_to_login'), new_user_registration_path %>
</p>
