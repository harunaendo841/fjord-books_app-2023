<!DOCTYPE html>
<html>
  <head>
    <title><%= t("layouts.navigation.brand") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
          <div class="container">
            <%= link_to t("layouts.navigation.brand"), root_path, class: "navbar-brand" %>

            <ul class="navbar-nav ml-auto">
              <li class="nav-item">
                <%= link_to t("layouts.navigation.users_index"), users_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <span class="nav-link"><%= current_user.email %></span>
              </li>
              <li class="nav-item">
                <%= link_to t("layouts.navigation.profile"), user_path(current_user), class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to t("layouts.navigation.logout"),
                        destroy_user_session_path,
                        data: { turbo_method: :delete },
                        class: "nav-link" %>
              </li>
            </ul>
          </div>
        </nav>
      </header>
    <% end %>

    <div class="container mt-4">
      <% flash.each do |key, msg| %>
        <div class="alert alert-<%= key == 'alert' ? 'danger' : 'success' %>">
          <%= msg %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
